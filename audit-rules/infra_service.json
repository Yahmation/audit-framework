{
  "id": "infra_service",
  "name": "Docker-wrapper infra service (no app code, just compose + config)",
  "checks": [
    {
      "id": "1.1",
      "name": "docker-compose.yml present",
      "type": "file_exists",
      "paths": ["docker-compose.yml", "compose.yml"],
      "severity": "required",
      "applies_to_project_types": ["infra"]
    },
    {
      "id": "1.2",
      "name": "Restart policy declared",
      "type": "grep",
      "pattern": "restart:\\s*(unless-stopped|always)",
      "paths": ["docker-compose.yml", "compose.yml"],
      "severity": "required",
      "applies_to_project_types": ["infra"]
    },
    {
      "id": "1.3",
      "name": "Health check declared",
      "type": "grep",
      "pattern": "healthcheck:",
      "paths": ["docker-compose.yml", "compose.yml"],
      "severity": "required",
      "applies_to_project_types": ["infra"]
    },
    {
      "id": "1.4",
      "name": "Memory limit declared (avoid OOM-killing the host)",
      "type": "grep",
      "pattern": "memory:\\s*\\d+(M|G)|limits:",
      "paths": ["docker-compose.yml", "compose.yml"],
      "severity": "recommended",
      "applies_to_project_types": ["infra"]
    },
    {
      "id": "2.1",
      "name": "Persistent named volume for data (no in-container stateful data)",
      "type": "grep",
      "pattern": "volumes:[\\s\\S]*?:/",
      "paths": ["docker-compose.yml", "compose.yml"],
      "severity": "required",
      "applies_to_project_types": ["infra"]
    },
    {
      "id": "2.2",
      "name": "Volume backed up by /root/backups/backup_all_dbs.sh OR documented separately",
      "type": "manual",
      "severity": "required"
    },
    {
      "id": "3.1",
      "name": "Traefik labels for reverse proxy (if exposed publicly)",
      "type": "grep",
      "pattern": "traefik\\.|Host\\(",
      "paths": ["docker-compose.yml", "compose.yml"],
      "severity": "recommended",
      "applies_to_project_types": ["infra"]
    },
    {
      "id": "3.2",
      "name": "TLS via Traefik certresolver (no plain http exposure)",
      "type": "grep",
      "pattern": "tls\\.certresolver|tls=true",
      "paths": ["docker-compose.yml", "compose.yml"],
      "severity": "recommended",
      "applies_to_project_types": ["infra"]
    },
    {
      "id": "4.1",
      "name": ".env loaded via env_file or environment with variable substitution (no secrets in compose)",
      "type": "grep_negative",
      "pattern": "(API_KEY|SECRET|TOKEN|PASSWORD)\\s*[:=]\\s*['\"]?[A-Za-z0-9_+/=]{16,}['\"]?",
      "paths": ["docker-compose.yml", "compose.yml"],
      "severity": "required",
      "applies_to_project_types": ["infra"]
    },
    {
      "id": "5.1",
      "name": "README documents start/stop/upgrade procedure",
      "type": "grep",
      "pattern": "docker compose|docker-compose",
      "paths": ["README.md"],
      "severity": "required",
      "applies_to_project_types": ["infra"]
    },
    {
      "id": "manual.upgrade-procedure",
      "name": "Upgrade procedure tested at least once (image pull → restart → verify)",
      "type": "manual",
      "severity": "recommended"
    },
    {
      "id": "manual.backup-tested",
      "name": "Backup restore tested at least once (DR drill)",
      "type": "manual",
      "severity": "required"
    },
    {
      "id": "manual.log-rotation",
      "name": "Docker log rotation configured (or limited via daemon.json max-size)",
      "type": "manual",
      "severity": "recommended"
    },
    {
      "id": "manual.monitoring",
      "name": "Service monitored (Uptime Kuma, Prometheus, or equivalent)",
      "type": "manual",
      "severity": "required"
    }
  ]
}
