      "severity": "required"
    },
    {
      "id": "manual.offsite-copy",
      "name": "Off-site backup copy (different provider/region)",
      "type": "manual",
      "severity": "required"
    },
    {
      "id": "manual.restore-procedure",
      "name": "Step-by-step restore procedure in RUNBOOK.md with timing estimates",
      "type": "manual",
      "severity": "required"
    },
    {
      "id": "manual.quarterly-drill",
